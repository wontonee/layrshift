{
    "name": "wontonee/layrshift",
    "description": "LayrShift \u2014 MCP server for AI agents to build inside WordPress (dev/staging only).",
    "version": "1.0.8",
    "type": "wordpress-plugin",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Saju Gopal",
            "email": "saju@wontonee.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "wordpress/mcp-adapter": "^0.5"
    },
    "autoload": {
        "psr-4": {
            "LayrShift\\": "includes/",
            "LayrShift\\Gutenberg\\": "includes/gutenberg/",
            "LayrShift\\Elementor\\": "includes/elementor/",
            "LayrShift\\Yoast\\": "includes/yoast/",
            "LayrShift\\Smush\\": "includes/smush/",
            "LayrShift\\VaultShift\\": "includes/vaultshift/",
            "LayrShift\\Blogibot\\": "includes/blogibot/",
            "LayrShift\\WpRocket\\": "includes/wp-rocket/",
            "LayrShift\\MigrateGuru\\": "includes/migrate-guru/",
            "LayrShift\\LiteSpeed\\": "includes/litespeed/",
            "LayrShift\\WpOptimize\\": "includes/wp-optimize/",
            "LayrShift\\WpFastestCache\\": "includes/wp-fastest-cache/",
            "LayrShift\\WooCommerce\\": "includes/woocommerce/",
            "LayrShift\\RankMath\\": "includes/rank-math/",
            "LayrShift\\Genesis\\": "includes/genesis/",
            "LayrShift\\Astra\\": "includes/astra/",
            "LayrShift\\ContactForm7\\": "includes/contact-form-7/",
            "LayrShift\\Wordfence\\": "includes/wordfence/",
            "LayrShift\\UpdraftPlus\\": "includes/updraftplus/",
            "LayrShift\\Abilities\\": "abilities/",
            "LayrShift\\Skills\\": "includes/skills/",
            "LayrShift\\Api\\": "api/",
            "LayrShift\\Admin\\": "admin/",
            "LayrShift\\PrismShift\\": "includes/prismshift/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "scripts": {
        "test": "phpunit"
    },
    "autoload-dev": {
        "psr-4": {
            "LayrShift\\Tests\\": "tests/"
        }
    }
}
